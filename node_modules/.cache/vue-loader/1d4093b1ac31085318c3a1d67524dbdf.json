doId++,\r\n                    text: 'ahaha'\r\n                }\r\n            ]\r\n        }\r\n    },\r\n    methods:{\r\n        addTodo() {\r\n          const trimedText = this.newTodoText.trim()\r\n          if (trimedText) {\r\n              this.todos.push(\r\n                  {\r\n                      id: nextTodoId++,\r\n                      text: trimedText\r\n                  }\r\n              )\r\n            this.newTodoText = ''\r\n          }\r\n        },\r\n        removeTodo(idtoRemove) {\r\n            this.todos = this.todos.filter(todo => { return todo.id !== idtoRemove})\r\n        }\r\n    }\r\n}\r\n</script>\r\n"]}]}